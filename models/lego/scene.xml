    <body name="brick" pos="0 0 0.05">

      <!-- Collision geometry (approx box) -->
      <geom type="box"
            size="0.004 0.004 0.0048"
            density="1200"
            rgba="0 0 0 0"/>

      <!-- Visual mesh -->
      <geom type="mesh"
            mesh="brick_vis"
            rgba="1 0 0 1"
            contype="0"
            conaffinity="0"/>
    </body>
